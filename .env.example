# Database
DATABASE_URL=postgresql://nihongo:password@localhost:5432/nihongo
POSTGRES_PASSWORD=password  # Used by docker-compose for the db service

# Auth.js
AUTH_SECRET=  # Generate with: npx auth secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ADMIN_EMAILS=  # Comma-separated list of Google emails allowed to access /admin

# AWS (for Polly TTS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
